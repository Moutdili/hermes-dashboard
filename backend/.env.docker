# Docker environment — used by docker-compose
# PostgreSQL
POSTGRES_USER=vv_admin
POSTGRES_PASSWORD=vv_admin_secret
POSTGRES_DB=ville_en_vogue

# Backend (DASH_ prefix)
DASH_HOST=0.0.0.0
DASH_PORT=8899
DASH_DEBUG=false
DASH_PG_HOST=postgres
DASH_PG_PORT=5432
DASH_PG_USER=vv_admin
DASH_PG_PASSWORD=vv_admin_secret
DASH_PG_DATABASE=ville_en_vogue
DASH_CORS_ORIGINS=http://localhost:3000
DASH_DEFAULT_IP=127.0.0.1
