# Hermes Dashboard — Backend environment
# Copy this to .env and fill in your values

# Server
DASH_HOST=0.0.0.0
DASH_PORT=8899
DASH_DEBUG=false

# PostgreSQL
DASH_PG_HOST=localhost
DASH_PG_PORT=5433
DASH_PG_USER=vv_admin
DASH_PG_PASSWORD=your_password_here
DASH_PG_DATABASE=ville_en_vogue

# Auth
DASH_TAILSCALE_ENABLED=true
DASH_DEFAULT_IP=127.0.0.1

# CORS (comma-separated origins)
DASH_CORS_ORIGINS=http://localhost:3000
